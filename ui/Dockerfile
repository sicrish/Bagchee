FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
ARG REACT_APP_API_URL
ARG REACT_APP_ENCRYPTION_SECRET
ARG REACT_APP_EXCHANGE_RATE_API_KEY
ARG REACT_APP_RAZORPAY_KEY_ID
ENV REACT_APP_API_URL=$REACT_APP_API_URL
ENV REACT_APP_ENCRYPTION_SECRET=$REACT_APP_ENCRYPTION_SECRET
ENV REACT_APP_EXCHANGE_RATE_API_KEY=$REACT_APP_EXCHANGE_RATE_API_KEY
ENV REACT_APP_RAZORPAY_KEY_ID=$REACT_APP_RAZORPAY_KEY_ID
RUN npm run build

FROM node:20-alpine
WORKDIR /app
RUN npm install -g serve
COPY --from=build /app/build ./build
CMD ["sh", "-c", "serve -s build -l ${PORT:-3000}"]

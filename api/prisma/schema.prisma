  // Per-currency wire transfer bank details
  bankNameUsd            String  @default("") @map("bank_name_usd")
  bankIbanUsd            String  @default("") @map("bank_iban_usd")
  bankBicUsd             String  @default("") @map("bank_bic_usd")

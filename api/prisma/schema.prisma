  bankOwner              String  @default("") @map("bank_owner")
  bankName               String  @default("") @map("bank_name")
  emailsCopy             String  @default("") @map("emails_copy")

  // Payment gateway mode for Credit Card / PayPal
  // "deferred" = admin reviews first, then sends payment link

model NewsletterSubscriber {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  firstName  String   @default("") @map("first_name")
  lastName   String   @default("") @map("last_name")
  categories String[] @default([])
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("newsletter_subscribers")
}

// E-Gift cards purchased by customers and sent via email
model GiftCard {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  amount         Float
  balance        Float
  recipientEmail String   @map("recipient_email")
  recipientName  String   @map("recipient_name")
  senderName     String   @map("sender_name")
  message        String?
  isActive       Boolean  @default(true) @map("is_active")
  orderId        Int?     @map("order_id")
  purchasedAt    DateTime @default(now()) @map("purchased_at")

  @@index([code])
  @@map("gift_cards")
}

model ScheduledEmail {
  id         Int      @id @default(autoincrement())
  subject    String
  body       String
  audience   String[] @default([])  // ["subscribers", "members", "purchased", "categories"]
  categories String[] @default([])  // category filter (if "categories" is in audience)
  sendAt     DateTime @map("send_at")
  status     String   @default("pending") // "pending" | "sent" | "failed"
  sent       Int      @default(0)
  failed     Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([status, sendAt])
  @@map("scheduled_emails")
}


// Section title/label management (e.g. "Our Picks", "On Sale Now")
// Old DB: home_sections
// SCHEMA-CHECK: Added `tagline` (Mongoose model had it, Prisma missed it). Added @unique on `section` (Mongoose enforced unique). Verify tagline is used in frontend.
model HomeSection {
  id      Int    @id @default(autoincrement())
  section String @unique
  title   String
  tagline String @default("")

  products HomeSectionProduct[]

  @@map("home_sections")
}

// Products that appear in editable home sections (section 1, section 2, etc.)
// Old DB: had separate home_section_1 and home_section_2 tables
// Decision: unified into one table with sectionId FK — cleaner, extensible
model HomeSectionProduct {
  id            Int         @id @default(autoincrement())
  homeSectionId Int         @map("home_section_id")
  productId     Int         @map("product_id")
  title         String      @default("") // display title override
  active        Boolean     @default(true)
  order         Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  homeSection   HomeSection @relation(fields: [homeSectionId], references: [id], onDelete: Cascade)

  @@index([homeSectionId])
  @@index([productId])
  @@map("home_section_products")
}

// Books of the Month — a curated monthly collection
// MongoDB: BooksOfMonth.model.js had products[] array
// We split into two tables: the collection header + a junction for its products
model BooksOfMonth {
  id         Int                  @id @default(autoincrement())
  monthName  String               @map("month_name")   // e.g. "February 2026"
  headline   String?              // e.g. "Our Romantic Picks"
  expiryDate DateTime             @map("expiry_date")
  isActive   Boolean              @default(true) @map("is_active")
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  products   BooksOfMonthProduct[]

  @@map("books_of_month")
}

// Junction table — which products belong to which Books of the Month collection
// SCHEMA-CHECK: Added `product Product @relation(...)` — was missing, making `include: { product: true }` impossible. Also need backref `booksOfMonth BooksOfMonthProduct[]` on Product model.
model BooksOfMonthProduct {
  id             Int          @id @default(autoincrement())
  booksOfMonthId Int          @map("books_of_month_id")
  productId      Int          @map("product_id")

  booksOfMonth   BooksOfMonth @relation(fields: [booksOfMonthId], references: [id], onDelete: Cascade)
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([booksOfMonthId, productId])
  @@index([booksOfMonthId])
  @@map("books_of_month_products")
}

// Homepage feature banner (title, description, two images — bg + overlay)
// Old DB: home_banners
// SCHEMA-CHECK: Completely redesigned. Original Prisma schema had generic `image/link/active/order` which did NOT match the Mongoose model or controller (which uses title, description, buttonText, accentColor, bgImageName, overlayImageName, status). Verify with frontend banner component.
model Banner {
  id               Int      @id @default(autoincrement())
  title            String
  description      String   @default("")
  buttonText       String   @default("Explore Now") @map("button_text")
  accentColor      String   @default("bg-hero-primary") @map("accent_color")
  bgImageName      String   @default("") @map("bg_image_name")
  overlayImageName String   @default("") @map("overlay_image_name")
  status           String   @default("active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("home_banners")
}

// Featured author on homepage
// Old DB: home_top_authors
// SCHEMA-CHECK: Added bookId, role, quote, timestamps. Mongoose model had all of these; original Prisma only had topAuthorId/active/order. Verify bookId references Product correctly in queries.
model TopAuthor {
  id        Int      @id @default(autoincrement())
  authorId  Int      @map("top_author_id")
  bookId    Int?     @map("book_id")
  role      String   @default("")
  quote     String   @default("")
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("home_top_authors")
}

